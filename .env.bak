# Base Wallet Address where USDC payments will be received (from your original Coinbase account)
BASE_WALLET_ADDRESS=0x6F275aB348EF19456C3f53bfb2A3122CaCaa1A7d

# Base Mainnet Network Configuration
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://x402.org/facilitator

# Redis Cache Settings
REDIS_URL=redis://localhost:6379/0
MAX_REGIME_AGE_SECONDS=999999

# Billing prices in USDC atomic units (6 decimals)
# 19000 = 0.019 USDC per call
TOOL_PRICE_ATOMIC=19000
# 150000000 = 150.00 USDC for 10,000 credit packs
CREDIT_PACK_CALLS=10000
CREDIT_PACK_PRICE_ATOMIC=150000000
